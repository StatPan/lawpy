# =============================================================================
# lawpy — API Key Configuration
# =============================================================================
# Copy this file to .env and fill in the keys for the countries you need.
# Only the keys for countries you actually use are required.

# -----------------------------------------------------------------------------
# 🇰🇷  South Korea — National Law Information Center (법제처 OpenAPI)
# -----------------------------------------------------------------------------
# Registration: https://open.law.go.kr/LSO/openApi/cuAskList.do
#
# What is the API key?
#   Your API key is the EMAIL USERNAME — the part BEFORE the @ symbol.
#
#   Example:
#     Registered email : user@example.com
#     API key to set   : user
#
# Note: Do NOT include the @domain part. The full email will NOT work.
#
LAWPY_KR_API_KEY=your-law-go-kr-email-username

# -----------------------------------------------------------------------------
# 🇯🇵  Japan — e-Gov API  (planned)
# -----------------------------------------------------------------------------
# LAWPY_JP_API_KEY=your-egov-api-key

# -----------------------------------------------------------------------------
# 🇺🇸  USA — Congress.gov API  (planned)
# -----------------------------------------------------------------------------
# LAWPY_US_API_KEY=your-congress-gov-api-key

# -----------------------------------------------------------------------------
# PyPI publishing (maintainers only — not needed for library users)
# -----------------------------------------------------------------------------
# PYPI_API_KEY=pypi-...
